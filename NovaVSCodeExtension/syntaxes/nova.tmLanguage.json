{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nova",
  "scopeName": "source.nova",
  "patterns": [
    {
      "name": "comment.line.double-slash.nova",
      "match": "//.*$"
    },
    {
      "name": "string.quoted.double.nova",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.nova",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "keyword.control.nova",
      "match": "\\b(when|otherwise|while|pause|if|else|for|return|break|continue)\\b"
    },
    {
      "name": "keyword.declaration.nova",
      "match": "\\b(have|put|write_file|read_file|ui_window|ui_message|icon|label|button|clicked|App\\.Exit|Application\\.Exit)\\b"
    },
    {
      "name": "entity.name.function.nova",
      "match": "\\b(ui_window|ui_message|set_icon|label|button|clicked|App\\.Exit|Application\\.Exit)\\b"
    },
    {
      "name": "variable.language.nova",
      "match": "\\b(this|self|super)\\b"
    },
    {
      "name": "constant.numeric.nova",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    {
      "name": "keyword.operator.nova",
      "match": "(\\+|\\-|\\*|\\/|\\=|\\=\\=|\\>|\\<|\\!\\=|\\>=|<=|\\+=|\\-=|\\*=|\\/=)"
    },
    {
      "name": "punctuation.separator.nova",
      "match": "[,;]"
    },
    {
      "name": "punctuation.bracket.nova",
      "match": "[\\[\\]\\{\\}\\(\\)]"
    },
    {
      "name": "constant.language.boolean.nova",
      "match": "\\b(true|false)\\b"
    },
    {
      "name": "constant.language.null.nova",
      "match": "\\b(null|nil)\\b"
    }
  ]
}