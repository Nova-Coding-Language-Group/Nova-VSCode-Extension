{
  "name": "nova-syntax",
  "displayName": "Nova Syntax",
  "description": "Syntax highlighting for the Nova programming language",
  "version": "1.1.0",
  "publisher": "KerbalMissile",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "NovaLanguageIcon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nova-Coding-Language-Group/Nova-Coding-Language.git"
  },
  "contributes": {
    "languages": [
      {
        "id": "nova",
        "aliases": [
          "Nova",
          "nova"
        ],
        "extensions": [
          ".nova"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nova",
        "scopeName": "source.nova",
        "path": "./syntaxes/nova.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "nova",
        "path": "./snippets/nova.json"
      }
    ]
  }
}